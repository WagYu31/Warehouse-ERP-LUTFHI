# ============================================================
#  WMS LUTFHI — Environment Variables Production
#  COPY FILE INI KE .env DAN ISI SEMUA VALUE
#  JANGAN COMMIT FILE .env KE GIT!
# ============================================================

# ─── Application ───────────────────────────────────────────
APP_ENV=production
APP_PORT=8080

# ─── Database (WAJIB diisi) ────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=wms_user
DB_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT_MIN_16_CHAR
DB_NAME=wms_lutfhi
DB_SSL_MODE=disable

# ─── JWT (WAJIB — min 32 karakter random) ──────────────────
# Generate: openssl rand -base64 48
JWT_SECRET=GANTI_DENGAN_SECRET_RANDOM_SANGAT_PANJANG_DAN_AMAN

# ─── CORS (pisahkan dengan koma) ───────────────────────────
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ─── Redis ─────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── MinIO (Object Storage) ────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=GANTI_DENGAN_MINIO_SECRET_KUAT
MINIO_BUCKET=wms-files
MINIO_USE_SSL=false

# ─── Email SMTP (untuk notifikasi) ─────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifikasi@perusahaan.com
SMTP_PASSWORD=app_password_gmail
SMTP_FROM=WMS LUTFHI <notifikasi@perusahaan.com>

# ─── Backup ────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=30
