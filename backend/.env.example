# WMS LUTFHI — Environment Variables
# Copy file ini ke .env dan sesuaikan nilainya
# JANGAN commit file .env ke git!

# ─── APP ─────────────────────────────────────────
APP_ENV=development
APP_PORT=8080
APP_NAME=WMS LUTFHI

# ─── DATABASE (PostgreSQL) ────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wms_lutfhi
DB_USER=wms_user
DB_PASSWORD=wms_password_2026
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# ─── REDIS ───────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_2026
REDIS_DB=0

# ─── JWT ─────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production_2026
JWT_EXPIRE_HOURS=8
REFRESH_EXPIRE_DAYS=7

# ─── FILE STORAGE (MinIO) ────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=wms_minio_admin
MINIO_SECRET_KEY=wms_minio_password_2026
MINIO_BUCKET=wms-files
MINIO_USE_SSL=false

# ─── EMAIL (Resend.com) ───────────────────────────
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=noreply@wms-lutfhi.com
EMAIL_FROM_NAME=WMS LUTFHI

# ─── WEB PUSH (PWA Notifications) ────────────────
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:admin@wms-lutfhi.com

# ─── CORS ────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
